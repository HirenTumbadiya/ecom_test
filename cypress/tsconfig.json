{
    "compilerOptions": {
        "target": "es2020",
        "lib": [
            "es2020",
            "dom"
        ],
        "ignoreDeprecations": "6.0",
        "types": [
            "cypress"
        ],
        "moduleResolution": "node",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true
    },
    "include": [
        "**/*.ts",
        "**/*.tsx"
    ]
}